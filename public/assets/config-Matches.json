{
  "heading": "Rebuilt-2026",
  "logo": "logo.png",

  "pages": [

    {
      "name": "Setup",
      "widgets": [
        {
          "name": "Starting Position",
          "type": "dropdown",
          "options": [
            "Left",
            "Center",
            "Right"
          ]
        },
        {
          "name": "Preloaded Fuel",
          "type": "checkbox"
        }
      ]
    },

    {
      "name": "Autonomous",
      "widgets": [
        {
          "name": "Mobility",
          "type": "checkbox"
        },
        {
          "name": "Auto Fuel Scored",
          "type": "spinbox"
        },
        {
          "name": "Auto Fuel Missed",
          "type": "spinbox"
        }
      ]
    },

    {
      "name": "Teleop",
      "widgets": [
        {
          "name": "Teleop Fuel Scored",
          "type": "spinbox"
        },
        {
          "name": "Teleop Fuel Missed",
          "type": "spinbox"
        },
        {
          "name": "Played Defense",
          "type": "checkbox"
        },
        {
          "name": "Driver Skill",
          "type": "radio",
          "options": [
            "Poor",
            "Average",
            "Good",
            "Elite"
          ]
        }
      ]
    },

    {
      "name": "Endgame",
      "widgets": [
        {
          "name": "Tower Climb",
          "type": "radio",
          "options": [
            "High Climb",
            "Mid Climb",
            "Low Climb",
            "None"
          ],
          "default": 3
        },
        {
          "name": "Failed Climb",
          "type": "checkbox"
        },
        {
          "name": "Robot Disabled",
          "type": "checkbox"
        },
        {
          "name": "Mechanical Issues",
          "type": "text"
        },
        {
          "name": "Scouter Name",
          "type": "text"
        }
      ]
    },

    {
      "name": "Score",
      "widgets": [
        {
          "name": "Total Fuel Scored",
          "type": "spinbox"
        },
        {
          "name": "Total Match Score",
          "type": "spinbox",
          "readonly": true
        }
      ]
    }

  ]
}
}
