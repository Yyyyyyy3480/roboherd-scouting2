{
  "heading": "Rebuilt-2026",
  "logo": "logo.png",
  "pages": [
    {
      "name": "Setup",
      "widgets": [
        {
          "name": "Starting Position",
          "type": "dropdown",
          "options": ["Left", "Center", "Right"]
        },
        {
          "name": "Preloaded Fuel",
          "type": "checkbox"
        }
      ]
    },
    {
      "name": "Autonomous",
      "widgets": [
        {
          "name": "Mobility",
          "type": "checkbox"
        },
        {
          "name": "Auto Fuel Scored",
          "type": "spinbox"
        },
        {
          "name": "Auto Fuel Missed",
          "type": "spinbox"
        },
        {
          "name": "Auto Fuel Accuracy (%)",
          "type": "spinbox",
          "readonly": true,
          "calculation": "(Autonomous['Auto Fuel Scored'] + Autonomous['Auto Fuel Missed'] > 0) ? (Autonomous['Auto Fuel Scored'] / (Autonomous['Auto Fuel Scored'] + Autonomous['Auto Fuel Missed']) * 100) : 0"
        }
      ]
    },
    {
      "name": "Teleop",
      "widgets": [
        {
          "name": "Teleop Fuel Scored",
          "type": "spinbox"
        },
        {
          "name": "Teleop Fuel Missed",
          "type": "spinbox"
        },
        {
          "name": "Teleop Fuel Accuracy (%)",
          "type": "spinbox",
          "readonly": true,
          "calculation": "(Teleop['Teleop Fuel Scored'] + Teleop['Teleop Fuel Missed'] > 0) ? (Teleop['Teleop Fuel Scored'] / (Teleop['Teleop Fuel Scored'] + Teleop['Teleop Fuel Missed']) * 100) : 0"
        },
        {
          "name": "Played Defense",
          "type": "checkbox"
        },
        {
          "name": "Driver Skill",
          "type": "radio",
          "options": ["Poor", "Average", "Good", "Elite"]
        }
      ]
    },
    {
      "name": "Endgame",
      "widgets": [
        {
          "name": "Tower Climb",
          "type": "radio",
          "options": ["High Climb", "Mid Climb", "Low Climb", "None"],
          "default": 3
        },
        {
          "name": "Hangar Points",
          "type": "spinbox",
          "default": 0
        },
        {
          "name": "Failed Climb",
          "type": "checkbox"
        },
        {
          "name": "Robot Disabled",
          "type": "checkbox"
        },
        {
          "name": "Mechanical Issues",
          "type": "text"
        },
        {
          "name": "Scouter Name",
          "type": "text"
        }
      ]
    },
    {
      "name": "Score",
      "widgets": [
        {
          "name": "Total Fuel Scored",
          "type": "spinbox",
          "readonly": true,
          "calculation": "Autonomous['Auto Fuel Scored'] + Teleop['Teleop Fuel Scored'] + (Setup['Preloaded Fuel'] ? 5 : 0)"
        },
        {
          "name": "Total Match Score",
          "type": "spinbox",
          "readonly": true,
          "calculation": "Autonomous['Auto Fuel Scored'] + Teleop['Teleop Fuel Scored'] + (Setup['Preloaded Fuel'] ? 5 : 0) + Endgame['Hangar Points'] + (Endgame['Tower Climb'] == 'High Climb' ? 30 : Endgame['Tower Climb'] == 'Mid Climb' ? 20 : Endgame['Tower Climb'] == 'Low Climb' ? 10 : 0)"
        }
      ]
    }
  ]
}
