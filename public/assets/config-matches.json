{
  "heading": "Rebuilt-2026",
  "logo": "logo.png",

  "pages": [

    {
      "name": "Setup",
      "widgets": [
        {
          "name": "Starting Position",
          "type": "dropdown",
          "options": [
            "Left",
            "Center",
            "Right"
          ]
        },
        {
          "name": "Preloaded Fuel",
          "type": "checkbox"
        }
      ]
    },

    {
      "name": "Autonomous",
      "widgets": [

        {
          "name": "Mobility",
          "type": "checkbox"
        },

        {
          "name": "Fuel Scored",
          "type": "spinbox",
          "prefix": "Auto"
        },

        {
          "name": "Fuel Missed",
          "type": "spinbox",
          "prefix": "Auto"
        }
      ]
    },

    {
      "name": "Teleop",
      "widgets": [

        {
          "name": "Fuel Scored",
          "type": "spinbox"
        },

        {
          "name": "Fuel Missed",
          "type": "spinbox"
        },

        {
          "name": "Fuel Picked Up",
          "type": "spinbox"
        },

        {
          "name": "Played Defense",
          "type": "checkbox"
        },

        {
          "name": "Driver Skill",
          "type": "radio",
          "options": [
            "Poor",
            "Average",
            "Good",
            "Elite"
          ]
        }
      ]
    },

    {
      "name": "Endgame",
      "widgets": [

        {
          "name": "Tower Climb",
          "type": "radio",
          "options": [
            "High Climb",
            "Mid Climb",
            "Low Climb",
            "Parked",
            "None"
          ],
          "default": 4
        },

        {
          "name": "Failed Climb",
          "type": "checkbox"
        },

        {
          "name": "Robot Disabled",
          "type": "checkbox"
        },

        {
          "name": "Mechanical Issues",
          "type": "text"
        },

        {
          "name": "Scouter Name",
          "type": "text"
        }
      ]
    },

    {
      "name": "Score",
      "widgets": [

        {
          "name": "Fuel Total",
          "type": "calc",
          "expression": "Auto_Fuel_Scored + Fuel_Scored"
        },

        {
          "name": "Climb Points",
          "type": "calc",
          "expression": "if(Tower_Climb == 0, 50, if(Tower_Climb == 1, 25, if(Tower_Climb == 2, 15, if(Tower_Climb == 3, 5, 0))))"
        },

        {
          "name": "Total Match Score",
          "type": "calc",
          "expression": "Fuel_Total + Climb_Points"
        }

      ]
    }

  ]
}
}
